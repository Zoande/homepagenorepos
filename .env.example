# Vercel Contact Broker Configuration
# Set these in Vercel Project Settings > Environment Variables.

# Receiver endpoint exposed by Cloudflare Tunnel.
# Example: https://ingest-dev.yourdomain.com/api/contact
RECEIVER_CONTACT_URL=

# Optional shared secret expected by receiver (x-receiver-token).
# Set REQUIRE_RECEIVER_TOKEN=true on receiver side when using this.
RECEIVER_TOKEN=

# Optional strict origin check for broker (preferred form).
# Comma-separated values, for example:
# https://elitedevs.org,https://www.elitedevs.org
ALLOWED_ORIGINS=

# Backward-compatible single-origin setting.
# ALLOWED_ORIGIN=https://elitedevs.org
ALLOWED_ORIGIN=

# Optional broker controls.
BROKER_RATE_LIMIT_MAX=6
BROKER_RATE_LIMIT_WINDOW_MS=60000
RECEIVER_TIMEOUT_MS=7000
